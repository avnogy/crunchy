JELLYFIN_API_URL=http://example.something:8096
JELLYFIN_API_KEY=replace-me
JELLYFIN_USER_ID=replace-me
# Optional. On first boot if unset crunchy generates and logs a password.
APP_PASSWORD=
SETTINGS_FILE=/config/settings.json
APP_UID=1000
APP_GID=1000
TRANSCODING_TEMP_DIR=/data/temp
OUTPUT_DIR=/data/output
MAX_CONCURRENT_JOBS=1
JOBS_POLL_INTERVAL_MS=3000
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
FFMPEG_FLAGS=
